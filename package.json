{
  "name": "farm-parse",
  "version": "2.0.0",
  "description": "Farm Parse desktop shell and maturity reminder dashboard",
  "main": "electron-main.js",
  "bin": "start-all.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "start": "node start-all.js",
    "proxy": "node proxy-server.js",
    "maturity": "node maturity-server.js",
    "desktop": "electron .",
    "start:all": "node start-all.js",
    "check": "node --check start-all.js && node --check proxy-server.js && node --check maturity-server.js && node --check lib/maturity.js && node --check lib/farm-db.js && node --check notify/pushplus.js && node --check electron-main.js && node --check js/maturity-api-fallback.js && node --check js/proxy-page-fixes.js && node --check js/maturity-core.js && node --check js/maturity-extra.js && node --check js/maturity-detail.js && node --check js/pushplus-settings.js",
    "build": "node build.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/farm-parse-v2.0.0.exe",
    "build:mac": "pkg . --targets node18-macos-x64 --output dist/farm-parse-v2.0.0",
    "desktop:pack": "electron-builder --dir",
    "desktop:win": "electron-builder --win",
    "desktop:mac": "electron-builder --mac"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonefly/farm-parse.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nonefly/farm-parse/issues"
  },
  "homepage": "https://github.com/nonefly/farm-parse#readme",
  "dependencies": {
    "express": "^5.2.1",
    "http-mitm-proxy": "^1.1.0",
    "protobufjs": "^8.2.0",
    "sql.js": "^1.13.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "pkg": "^5.8.0"
  },
  "pkg": {
    "scripts": [
      "start-all.js",
      "proxy-server.js",
      "maturity-server.js",
      "lib/**/*.js",
      "notify/**/*.js",
      "js/maturity-core.js",
      "js/maturity-extra.js",
      "js/maturity-detail.js",
      "js/pushplus-settings.js"
    ],
    "assets": [
      "auth.html",
      "index.html",
      "proxy.html",
      "maturity.html",
      "README.use.md",
      "README.maturity.md",
      "AI_CONTEXT.md",
      "js/**/*.js",
      "proto/**/*.proto",
      "data/**/*.json",
      "img/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  },
  "build": {
    "appId": "com.nonefly.farmparse",
    "productName": "Farm Parse",
    "asar": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron-main.js",
      "start-all.js",
      "proxy-server.js",
      "maturity-server.js",
      "auth.html",
      "index.html",
      "proxy.html",
      "maturity.html",
      "README.use.md",
      "README.maturity.md",
      "AI_CONTEXT.md",
      "lib/**/*",
      "notify/**/*",
      "js/**/*",
      "proto/**/*",
      "data/**/*",
      "img/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  }
}
